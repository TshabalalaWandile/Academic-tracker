<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Academic_tracker.Pages.LoginPage"
             Title="Login">

    <VerticalStackLayout Padding="30" Spacing="15">
        <Label Text="Welcome To TrackWise" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center"/>

        <Entry x:Name="EmailEntry" Placeholder="Email"/>
        <Entry x:Name="PasswordEntry" Placeholder="Password" IsPassword="True"/>

        <Button Text="Login" Clicked="OnLoginClicked"/>
        <Button Text="Register" Clicked="OnRegisterClicked"/>
    </VerticalStackLayout>

</ContentPage>