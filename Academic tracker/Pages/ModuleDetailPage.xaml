<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Academic_tracker.Pages.ModuleDetailPage"
             BackgroundColor="{StaticResource BackgroundColor}">

    <VerticalStackLayout Padding="20" Spacing="15">

        <Border BackgroundColor="{StaticResource PrimaryColor}" Padding="20"
                StrokeThickness="0" StrokeShape="RoundRectangle 15">
            <VerticalStackLayout>
                <Label x:Name="ModuleNameLabel" FontSize="24" FontAttributes="Bold" TextColor="White"
                       HorizontalOptions="Center"/>
                <Label x:Name="ModuleCodeLabel" FontSize="16" TextColor="{StaticResource AccentColor}"
                       HorizontalOptions="Center"/>
                <Label x:Name="TargetMarkLabel" FontSize="16" TextColor="White"
                       HorizontalOptions="Center"/>
                <Label x:Name="RunningMarkLabel" FontSize="16" TextColor="White"
                       HorizontalOptions="Center"/>
                <Label x:Name="StatusLabel" FontSize="16" FontAttributes="Bold"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Border>

        <CollectionView x:Name="AssessmentsCollection">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border BackgroundColor="{StaticResource CardColor}" Margin="0,5" Padding="20"
                            StrokeThickness="0" StrokeShape="RoundRectangle 15">
                        <Border.Shadow>
                            <Shadow Brush="Gray" Offset="0,2" Radius="5" Opacity="0.2"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="5">
                            <Label Text="{Binding AssessmentName}" FontSize="16" FontAttributes="Bold"
                                   TextColor="{StaticResource TextDark}"/>
                            <Label Text="{Binding Weighting, StringFormat='Weighting: {0}%'}"
                                   FontSize="14" TextColor="{StaticResource TextGray}"/>
                            <Label Text="{Binding MarkObtained, StringFormat='Mark: {0}'}"
                                   FontSize="14" TextColor="{StaticResource TextDark}"/>
                            <Label Text="{Binding TotalMark, StringFormat='Out of: {0}'}"
                                   FontSize="14" TextColor="{StaticResource TextDark}"/>
                            <HorizontalStackLayout Spacing="10" Margin="0,10,0,0">
                                <Button Text="Edit" Clicked="OnEditAssessmentClicked"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="{StaticResource SecondaryColor}"/>
                                <Button Text="Delete" Clicked="OnDeleteAssessmentClicked"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="{StaticResource DangerColor}"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Text="+ Add Assessment" Clicked="OnAddAssessmentClicked"/>
    </VerticalStackLayout>

</ContentPage>