<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Academic_tracker.Pages.ModuleDetailPage"
             Title="Module Detail">

    <VerticalStackLayout Padding="20" Spacing="15">
        <Label x:Name="ModuleNameLabel" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center"/>
        <Label x:Name="ModuleCodeLabel" FontSize="16" TextColor="Gray" HorizontalOptions="Center"/>
        <Label x:Name="TargetMarkLabel" FontSize="16" HorizontalOptions="Center"/>

        <CollectionView x:Name="AssessmentsCollection">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,5" Padding="15" BorderColor="LightGray">
                        <VerticalStackLayout>
                            <Label Text="{Binding AssessmentName}" FontSize="16" FontAttributes="Bold"/>
                            <Label Text="{Binding Weighting, StringFormat='Weighting: {0}%'}" FontSize="14" TextColor="Gray"/>
                            <Label Text="{Binding MarkObtained, StringFormat='Mark: {0}'}" FontSize="14"/>
                            <Label Text="{Binding TotalMark, StringFormat='Out of: {0}'}" FontSize="14"/>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Text="+ Add Assessment" Clicked="OnAddAssessmentClicked"/>
    </VerticalStackLayout>

</ContentPage>