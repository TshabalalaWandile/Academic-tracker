<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Academic_tracker.Pages.ForgotPasswordPage"
             BackgroundColor="{StaticResource BackgroundColor}">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="15" VerticalOptions="Center">

            <Label Text="Reset Password" FontSize="28" FontAttributes="Bold"
                   TextColor="{StaticResource PrimaryColor}" HorizontalOptions="Center"/>
            <Label Text="Enter your email to reset your password" FontSize="14"
                   TextColor="{StaticResource TextGray}" HorizontalOptions="Center" Margin="0,0,0,20"/>

            <Border BackgroundColor="{StaticResource CardColor}" Padding="25" StrokeThickness="0"
                    StrokeShape="RoundRectangle 15">
                <VerticalStackLayout Spacing="12">

                    <Label Text="Email" FontAttributes="Bold" TextColor="{StaticResource TextDark}"/>
                    <Entry x:Name="EmailEntry" Placeholder="Enter your registered email"/>

                    <Label Text="New Password" FontAttributes="Bold" TextColor="{StaticResource TextDark}"/>
                    <Entry x:Name="NewPasswordEntry" Placeholder="Enter new password" IsPassword="True"/>

                    <Label Text="Confirm New Password" FontAttributes="Bold" TextColor="{StaticResource TextDark}"/>
                    <Entry x:Name="ConfirmPasswordEntry" Placeholder="Confirm new password" IsPassword="True"/>

                    <Button Text="Reset Password" Clicked="OnResetClicked" Margin="0,10,0,0"/>
                    <Button Text="Back to Login" Clicked="OnBackClicked"
                            BackgroundColor="{StaticResource AccentColor}"
                            TextColor="{StaticResource PrimaryColor}"/>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>