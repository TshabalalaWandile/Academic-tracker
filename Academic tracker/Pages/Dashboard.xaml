<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Academic_tracker.Pages.Dashboard"
             Title="My Modules">

    <VerticalStackLayout Padding="20" Spacing="15">
        <Label Text="My Modules" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center"/>

        <CollectionView x:Name="ModulesCollection">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,5" Padding="15" Stroke="LightGray">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnModuleTapped"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout>
                            <Label Text="{Binding ModuleName}" FontSize="18" FontAttributes="Bold"/>
                            <Label Text="{Binding ModuleCode}" FontSize="14" TextColor="Gray"/>
                            <Label Text="{Binding RunningMarkDisplay}" FontSize="14"/>
                            <Label Text="{Binding StatusDisplay}" FontSize="14" FontAttributes="Bold"
                                   TextColor="{Binding StatusColor}"/>
                            <HorizontalStackLayout Spacing="10" Margin="0,10,0,0">
                                <Button Text="Edit" Clicked="OnEditModuleClicked" CommandParameter="{Binding .}"/>
                                <Button Text="Delete" Clicked="OnDeleteModuleClicked" CommandParameter="{Binding .}"
                                        BackgroundColor="Red" TextColor="White"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Text="+ Add Module" Clicked="OnAddModuleClicked"/>
    </VerticalStackLayout>

</ContentPage>