<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Academic_tracker.Pages.Dashboard"
             BackgroundColor="{StaticResource BackgroundColor}">

    <VerticalStackLayout Padding="20" Spacing="15">
        <Label Text="My Modules" FontSize="28" FontAttributes="Bold"
               TextColor="{StaticResource PrimaryColor}" HorizontalOptions="Center"/>

        <CollectionView x:Name="ModulesCollection">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border BackgroundColor="{StaticResource CardColor}" Margin="0,5" Padding="20"
                            StrokeThickness="0" StrokeShape="RoundRectangle 15">
                        <Border.Shadow>
                            <Shadow Brush="Gray" Offset="0,2" Radius="5" Opacity="0.2"/>
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnModuleTapped"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="5">
                            <Label Text="{Binding ModuleName}" FontSize="18" FontAttributes="Bold"
                                   TextColor="{StaticResource TextDark}"/>
                            <Label Text="{Binding ModuleCode}" FontSize="14"
                                   TextColor="{StaticResource TextGray}"/>
                            <Label Text="{Binding RunningMarkDisplay}" FontSize="14"
                                   TextColor="{StaticResource TextDark}"/>
                            <Label Text="{Binding StatusDisplay}" FontSize="14" FontAttributes="Bold"
                                   TextColor="{Binding StatusColor}"/>
                            <HorizontalStackLayout Spacing="10" Margin="0,10,0,0">
                                <Button Text="Edit" Clicked="OnEditModuleClicked"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="{StaticResource SecondaryColor}"/>
                                <Button Text="Delete" Clicked="OnDeleteModuleClicked"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="{StaticResource DangerColor}"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Text="+ Add Module" Clicked="OnAddModuleClicked"
                BackgroundColor="{StaticResource PrimaryColor}"/>
    </VerticalStackLayout>

</ContentPage>