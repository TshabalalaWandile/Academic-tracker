<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Academic_tracker.Pages.RegisterPage"
             BackgroundColor="{StaticResource BackgroundColor}">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="15" VerticalOptions="Center">

            <Label Text="Create Account" FontSize="28" FontAttributes="Bold"
                   TextColor="{StaticResource PrimaryColor}" HorizontalOptions="Center"/>
            <Label Text="Join TrackWise Today" FontSize="14"
                   TextColor="{StaticResource TextGray}" HorizontalOptions="Center" Margin="0,0,0,20"/>

            <Border BackgroundColor="{StaticResource CardColor}" Padding="25" StrokeThickness="0"
                    StrokeShape="RoundRectangle 15">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Username" FontAttributes="Bold" TextColor="{StaticResource TextDark}"/>
                    <Entry x:Name="UsernameEntry" Placeholder="Enter your username"/>

                    <Label Text="Email" FontAttributes="Bold" TextColor="{StaticResource TextDark}"/>
                    <Entry x:Name="EmailEntry" Placeholder="Enter your email"/>

                    <Label Text="Password" FontAttributes="Bold" TextColor="{StaticResource TextDark}"/>
                    <Entry x:Name="PasswordEntry" Placeholder="Enter your password" IsPassword="True"/>

                    <Button Text="Register" Clicked="OnRegisterClicked" Margin="0,10,0,0"/>
                    <Button Text="Back to Login" Clicked="OnBackClicked"
                            BackgroundColor="{StaticResource AccentColor}"
                            TextColor="{StaticResource PrimaryColor}"/>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>