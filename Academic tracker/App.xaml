<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Academic_tracker.App">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="PrimaryColor">#6A0DAD</Color>
            <Color x:Key="SecondaryColor">#9B59B6</Color>
            <Color x:Key="AccentColor">#D7BDE2</Color>
            <Color x:Key="BackgroundColor">#F5F0FB</Color>
            <Color x:Key="CardColor">#FFFFFF</Color>
            <Color x:Key="DangerColor">#E74C3C</Color>
            <Color x:Key="SuccessColor">#27AE60</Color>
            <Color x:Key="WarningColor">#F39C12</Color>
            <Color x:Key="TextDark">#2C3E50</Color>
            <Color x:Key="TextGray">#7F8C8D</Color>

            <Style TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource PrimaryColor}"/>
                <Setter Property="TextColor" Value="White"/>
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="Padding" Value="12,10"/>
                <Setter Property="FontAttributes" Value="Bold"/>
            </Style>

            <Style TargetType="Entry">
                <Setter Property="BackgroundColor" Value="White"/>
                <Setter Property="TextColor" Value="{StaticResource TextDark}"/>
                <Setter Property="PlaceholderColor" Value="{StaticResource TextGray}"/>
                <Setter Property="Margin" Value="0,0,0,5"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>